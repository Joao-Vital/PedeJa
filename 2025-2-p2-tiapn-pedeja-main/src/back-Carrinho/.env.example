# Configurações do MySQL
DB_HOST=localhost
DB_PORT=3306
DB_NAME=pedeja
DB_USER=root
DB_PASSWORD=senha-secreta

# Pool de conexões (opcional)
DB_POOL_MAX=10
DB_POOL_MIN=0
DB_POOL_IDLE=30000
DB_WAIT_FOR_CONNECTIONS=true

# Autenticação e CORS
JWT_SECRET=troque-este-segredo
JWT_EXPIRES_IN=2h
ALLOWED_ORIGINS=http://localhost:3333,http://localhost:5500
