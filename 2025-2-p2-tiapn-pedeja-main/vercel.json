{
  "buildCommand": "echo 'No build required'",
  "outputDirectory": "src/front",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://pedeja-backend.onrender.com/api/:path*"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600"
        }
      ]
    }
  ]
}
